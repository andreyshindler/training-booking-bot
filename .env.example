# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# Telegram numeric user id of the trainer (admin). Get yours from @userinfobot
TRAINER_ID=123456789

# Optional settings
DB_PATH=bookings.db
TIMEZONE=UTC
BOOKING_DAYS_AHEAD=7

# Optional: HTTPS URL of the schedule-editing mini app (docs/index.html).
# Enables the trainer's "עריכת המערכת" button. Two ways to host it:
#
# Option A — GitHub Pages (quick, free, but publicly viewable by anyone with
# the link — see README):
# WEBAPP_URL=https://<username>.github.io/training-booking-bot/
#
# Option B — self-hosted on your own server, restricted to the admin only.
# Also set WEBAPP_SECRET (a long random value, e.g. `openssl rand -hex 32`);
# the bot serves the page itself on WEBAPP_PORT (see README for the nginx
# config to put in front of it) and only requests carrying that secret as a
# ?token= are allowed through:
# WEBAPP_URL=https://yourdomain.com/training-booking/
# WEBAPP_SECRET=
# WEBAPP_PORT=8082
